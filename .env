OPENAI_API_KEY="bedrock-api-key-"
OPENAI_API_BASE="https://bedrock-mantle.eu-north-1.api.aws/v1"

BIG_MODEL=mistral.devstral-2-123b
SMALL_MODEL=mistral.devstral-2-123b

BIG_PREFIXES=opus,sonnet
SMALL_PREFIXES=haiku

MAX_TOKENS=100000

# ═══════════════════════════════════════════════════════
# oddwebs — Frontend Environment Variables
# ═══════════════════════════════════════════════════════

# Google Sheets Webhook & Email Sender (Google Apps Script Web App URL)
# Deploy a Google Apps Script as a web app to log submissions and send confirmation/notification emails.
VITE_GOOGLE_SHEETS_WEBHOOK=YOUR_GOOGLE_APPS_SCRIPT_WEB_APP_URL

# oddwebs Admin/Destination Email Address
# Submissions and notifications will be forwarded here.
# For testing, you can use your testmail.app inbox address (e.g. namespace.tag@inbox.testmail.app)
VITE_ADMIN_EMAIL=GOUTAMDHANANI@gmail.com

# Google Analytics Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ═══════════════════════════════════════════════════════
# Resend Email Integration (Secure Server-Side Configuration)
# ═══════════════════════════════════════════════════════

# Set to 'true' to explicitly route bookings through the secure Resend API route
VITE_USE_RESEND=true

# Configure if hosting your backend serverless functions at a custom URL (e.g. AWS Lambda / Cloudflare Workers).
# Defaults to '/api/send-email' which works out-of-the-box when deploying to Vercel/Netlify.
# VITE_RESEND_API_URL=/api/send-email

# Resend API Key (Keep this secret! DO NOT prefix with VITE_ to prevent client-side exposure)
RESEND_API_KEY=re_anZQvxpL_5P1QCD2re5nNecDmFCqDS4j1

# Verified Resend Sender Email Address (e.g., info@yourdomain.com).
# 'onboarding@resend.dev' is default for sandboxed testing (only sends to your own registration email).
RESEND_FROM_EMAIL=oddwebs <appointment@oddwebs.com>